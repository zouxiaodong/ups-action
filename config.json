{
  "global": {
    "ssh_port": 22,
    "connect_timeout_seconds": 10,
    "execute_timeout_seconds": 120,
    "retry_count": 2,
    "retry_delay_seconds": 5,
    "log_dir": ".",
    "log_max_days": 30
  },
  "default_script": [
    "wall 'UPS power low, system will shutdown in 1 minute'",
    "sleep 10",
    "sync",
    "shutdown -h now"
  ],
  "servers": [
    {
      "host": "192.168.1.10",
      "port": 22,
      "user": "root",
      "password": "your_password_here",
      "script": [
        "systemctl stop nginx",
        "systemctl stop mysql",
        "sync",
        "shutdown -h now"
      ]
    },
    {
      "host": "192.168.1.11",
      "port": 22,
      "user": "root",
      "password": "your_password_here"
    }
  ]
}
